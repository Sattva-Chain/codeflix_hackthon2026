# =============================
# Asana Integration
# =============================
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=
REMEDIATION_TASK_DUE_DAYS=2

# =============================
# Google OAuth2 (Gmail) for Email Notifications
# =============================
GOOGLE_OAUTH_USER=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# Optional short-lived access token. Usually leave empty.
GOOGLE_OAUTH_ACCESS_TOKEN=

# Optional sender override. If empty, GOOGLE_OAUTH_USER is used.
SMTP_FROM=

# =============================
# SMTP fallback (optional)
# Used only if Google OAuth2 variables above are not set.
# =============================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# =============================
# Existing app variables (example)
# =============================
MONGODB_URI=
SECURE_SCAN_AI_URL=
